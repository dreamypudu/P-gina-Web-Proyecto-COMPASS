---
import { useTranslations, localizePath, type Lang } from '../i18n/utils';
import LangSwitch from './LangSwitch.astro';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const home = localizePath('/', lang);

const links = [
  { href: '#plataforma', label: t('nav.platform') },
  { href: '#soluciones', label: t('nav.solutions') },
  { href: '#como-funciona', label: t('nav.how') },
  { href: '#versiones', label: t('nav.versions') },
  { href: '#nosotros', label: t('nav.about') },
  { href: '#contacto', label: t('nav.contact') },
];
---
<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-50 transition-all duration-200"
  data-header
>
  <nav class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-4 lg:px-8" aria-label={t('nav.home')}>
    <a href={home} class="flex items-center gap-2 shrink-0" aria-label="COMPASS — Inicio">
      <img src="/assets/logo-compass.svg" alt="COMPASS" class="h-7 w-auto md:h-8" width="200" height="33" />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden items-center gap-7 lg:flex">
      {links.map((l) => (
        <li>
          <a href={l.href} class="navlink text-sm font-medium text-ink-dim hover:text-white transition-colors">{l.label}</a>
        </li>
      ))}
    </ul>

    <div class="hidden items-center gap-3 lg:flex">
      <LangSwitch lang={lang} />
      <a href="#contacto" class="rounded-full bg-cyan px-4 py-2 text-sm font-bold text-base-2 shadow-lg shadow-cyan/20 transition hover:bg-white hover:shadow-cyan/40">
        {t('nav.demo')}
      </a>
    </div>

    <!-- Mobile toggle -->
    <button
      type="button"
      class="inline-flex items-center justify-center rounded-lg border border-white/15 p-2 text-white lg:hidden"
      aria-label={t('nav.menu')}
      aria-expanded="false"
      aria-controls="mobile-drawer"
      data-menu-btn
    >
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" data-icon-open>
        <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round" />
      </svg>
      <svg class="hidden h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" data-icon-close>
        <path d="M6 6l12 12M18 6L6 18" stroke-linecap="round" />
      </svg>
    </button>
  </nav>

  <!-- Mobile drawer -->
  <div
    id="mobile-drawer"
    class="hidden border-t border-white/10 bg-base-2/95 backdrop-blur-lg lg:hidden"
    data-drawer
  >
    <ul class="mx-auto flex max-w-7xl flex-col gap-1 px-5 py-4">
      {links.map((l) => (
        <li>
          <a href={l.href} class="block rounded-lg px-3 py-3 text-base font-medium text-ink hover:bg-white/5" data-drawer-link>{l.label}</a>
        </li>
      ))}
      <li class="mt-2 flex items-center justify-between gap-3">
        <LangSwitch lang={lang} />
        <a href="#contacto" class="flex-1 rounded-full bg-cyan px-4 py-3 text-center text-sm font-bold text-base-2" data-drawer-link>
          {t('nav.demo')}
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const header = document.querySelector<HTMLElement>('[data-header]');
  const btn = document.querySelector<HTMLButtonElement>('[data-menu-btn]');
  const drawer = document.querySelector<HTMLElement>('[data-drawer]');
  const iconOpen = document.querySelector<SVGElement>('[data-icon-open]');
  const iconClose = document.querySelector<SVGElement>('[data-icon-close]');

  // Sticky background after 80px
  const onScroll = () => {
    if (!header) return;
    if (window.scrollY > 80) header.setAttribute('data-scrolled', '');
    else header.removeAttribute('data-scrolled');
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // Mobile drawer
  const setOpen = (open: boolean) => {
    if (!drawer || !btn) return;
    drawer.classList.toggle('hidden', !open);
    btn.setAttribute('aria-expanded', String(open));
    iconOpen?.classList.toggle('hidden', open);
    iconClose?.classList.toggle('hidden', !open);
  };
  btn?.addEventListener('click', () => setOpen(drawer?.classList.contains('hidden') ?? true));
  document.querySelectorAll('[data-drawer-link]').forEach((a) =>
    a.addEventListener('click', () => setOpen(false))
  );
</script>

<style>
  [data-header][data-scrolled] {
    background-color: color-mix(in srgb, var(--color-base-2) 88%, transparent);
    backdrop-filter: blur(12px);
    box-shadow: 0 10px 30px -15px rgb(0 0 0 / 0.8);
    border-bottom: 1px solid rgb(255 255 255 / 0.06);
  }
</style>
