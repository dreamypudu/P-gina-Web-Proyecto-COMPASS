---
import { localizePath, useTranslations, type Lang } from '../i18n/utils';
import LangSwitch from './LangSwitch.astro';

interface Props { lang: Lang }

const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
const links = [
  { href: '#plataforma', label: t('nav.platform') },
  { href: '#soluciones', label: t('nav.solutions') },
  { href: '#como-funciona', label: t('nav.how') },
  { href: '#versiones', label: t('nav.versions') },
  { href: '#nosotros', label: t('nav.about') },
  { href: '#contacto', label: t('nav.contact') },
];
const contactEmail = 'contacto@compass.giia.udec.cl';
---
<footer class="border-t border-white/10 bg-base-2/70 py-12">
  <div class="mx-auto grid max-w-7xl gap-10 px-5 lg:grid-cols-[1.2fr_0.8fr_0.8fr] lg:px-8">
    <div>
      <a href={localizePath('/', lang)} class="inline-flex" aria-label="COMPASS">
        <img src="/assets/logo-compass.svg" alt="COMPASS" class="h-8 w-auto" width="200" height="33" />
      </a>
      <p class="mt-4 max-w-md text-lg font-semibold text-white">{t('footer.tagline')}</p>
      <p class="mt-3 max-w-md text-sm leading-relaxed text-ink-dim">{t('footer.madeBy')}</p>
    </div>

    <div>
      <p class="text-xs font-bold uppercase text-cyan">{t('footer.navLabel')}</p>
      <ul class="mt-4 grid gap-2">
        {links.map((link) => (
          <li><a href={link.href} class="text-sm text-ink-dim transition hover:text-white">{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <p class="text-xs font-bold uppercase text-cyan">{t('footer.contactLabel')}</p>
      <a href={`mailto:${contactEmail}`} class="mt-4 inline-flex text-sm font-semibold text-ink-dim transition hover:text-white">{contactEmail}</a>
      <div class="mt-5"><LangSwitch lang={lang} /></div>
    </div>
  </div>

  <div class="mx-auto mt-10 max-w-7xl px-5 lg:px-8">
    <div class="hairline"></div>
    <p class="mt-6 text-sm text-ink-dim">&copy; {year} COMPASS · {t('footer.rights')}</p>
  </div>
</footer>
