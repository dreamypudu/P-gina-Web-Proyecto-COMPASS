---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props { lang: Lang }

const { lang } = Astro.props;
const t = useTranslations(lang);
const upcoming = t<{ name: string; desc: string }[]>('versions.upcoming');
---
<section id="versiones" class="relative py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="kicker justify-center" data-reveal>{t('versions.kicker')}</p>
      <h2 class="mt-5 text-3xl sm:text-4xl lg:text-5xl" data-reveal style="--reveal-delay:80ms">{t('versions.title')}</h2>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-3">
      <article class="card glow lift relative overflow-hidden p-8 lg:col-span-2" data-reveal>
        <div class="absolute inset-0 bg-gradient-to-br from-cyan/12 via-transparent to-indigo/15" aria-hidden="true"></div>
        <div class="relative">
          <span class="inline-flex rounded-full border border-cyan/30 bg-cyan/10 px-3 py-1 text-xs font-bold uppercase text-cyan">
            {t('versions.available')}
          </span>
          <h3 class="mt-5 text-3xl">{t('versions.activeName')}</h3>
          <p class="mt-4 max-w-2xl text-lg leading-relaxed text-ink-dim">{t('versions.activeDesc')}</p>
          <a href="#contacto" class="mt-7 inline-flex items-center gap-2 rounded-full border border-cyan/40 px-5 py-3 font-semibold text-cyan transition hover:bg-cyan hover:text-base-2">
            {t('versions.activeCta')}
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </article>

      <article class="card lift flex flex-col justify-between p-8" data-reveal style="--reveal-delay:120ms">
        <div>
          <span class="inline-flex rounded-full border border-white/10 bg-white/[0.03] px-3 py-1 text-xs font-bold uppercase text-ink-dim">
            {t('versions.soon')}
          </span>
          <h3 class="mt-5 text-2xl">{t('versions.customName')}</h3>
          <p class="mt-4 leading-relaxed text-ink-dim">{t('versions.customDesc')}</p>
        </div>
        <a href="#contacto" class="mt-7 inline-flex items-center gap-2 text-sm font-bold text-cyan hover:text-white">
          {t('versions.customCta')}
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </article>
    </div>

    <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {upcoming.map((item, i) => (
        <article class="version-card card lift p-6" data-reveal style={`--reveal-delay:${i * 90}ms`}>
          <span class="text-xs font-bold uppercase text-ink-dim">{t('versions.soon')}</span>
          <h3 class="mt-4 text-xl">{item.name}</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-dim">{item.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .version-card {
    filter: saturate(0.72);
    opacity: 0.78;
  }
  .version-card:hover {
    filter: saturate(1);
    opacity: 1;
  }
</style>
