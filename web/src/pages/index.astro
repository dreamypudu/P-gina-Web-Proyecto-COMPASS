---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Story from '../components/Story.astro';
import DiceVsHace from '../components/DiceVsHace.astro';
import Platform from '../components/Platform.astro';
import Solutions from '../components/Solutions.astro';
import Democratize from '../components/Democratize.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Versions from '../components/Versions.astro';
import Savings from '../components/Savings.astro';
import Future from '../components/Future.astro';
import About from '../components/About.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const lang = 'es';
---
<BaseLayout lang={lang}>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <Story lang={lang} />
    <DiceVsHace lang={lang} />
    <Platform lang={lang} />
    <Solutions lang={lang} />
    <Democratize lang={lang} />
    <HowItWorks lang={lang} />
    <Versions lang={lang} />
    <Savings lang={lang} />
    <Future lang={lang} />
    <About lang={lang} />
    <CTA lang={lang} />
  </main>
  <Footer lang={lang} />
</BaseLayout>
